# ─────────────────────────────────────────────────
#  Rent & Tenant Management System — Monorepo .gitignore
# ─────────────────────────────────────────────────

# ── Dependencies (all three packages) ─────────────
node_modules/
backend/node_modules/
web/node_modules/
mobile/node_modules/

# ── Environment files (NEVER commit secrets) ──────
.env
backend/.env
web/.env
mobile/.env

# ── Build outputs ─────────────────────────────────
dist/
dist-ssr/
web/dist/
backend/dist/
mobile/.expo/
mobile/dist/

# ── Expo / React Native ────────────────────────────
mobile/.expo-shared/
mobile/android/
mobile/ios/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# ── Logs ──────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS / Editor ────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.sw?

# ── Misc ──────────────────────────────────────────
*.local
coverage/
.cache/
