# ======================================================================
# Mobile App - Firebase Configuration
# ======================================================================
# Copy to .env and fill in your Firebase credentials

# Backend API URL (use your machine's LAN IP for device/emulator)
# For Android Emulator: 10.0.2.2:5000
# For iOS Simulator or Physical Device: your-machine-ip:5000
EXPO_PUBLIC_API_URL=http://192.168.1.x:5000/api

# ======================================================================
# Firebase Configuration
# ======================================================================
# Get these from Firebase Console → Project Settings

EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

